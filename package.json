{
  "name": "audio-to-text-desktop-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:frontend": "npm install --prefix frontend",
    "dev": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && npx @tauri-apps/cli dev -c src-tauri/tauri.conf.json",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:lint": "npm run lint --prefix frontend",
    "tauri:check": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && cargo check --manifest-path src-tauri/Cargo.toml",
    "worker:check": "venv\\Scripts\\python.exe -m py_compile run.py worker\\cli.py worker\\core.py worker\\events.py"
  }
}
