{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AudioToText Desktop",
  "version": "0.1.0",
  "identifier": "com.wangk.audio_to_text",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AudioToText Desktop",
        "width": 1520,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "resources": [
      "../worker/__init__.py",
      "../worker/cli.py",
      "../worker/core.py",
      "../worker/events.py",
      "../run.py",
      "../requirements.txt"
    ]
  }
}
